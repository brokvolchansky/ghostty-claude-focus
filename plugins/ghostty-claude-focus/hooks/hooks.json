{
  "Notification": [
    {
      "hooks": [
        { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/notify.sh Notification" }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/notify.sh Stop" }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "hooks": [
        { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/notify.sh PermissionRequest" }
      ]
    }
  ],
  "SessionStart": [
    {
      "hooks": [
        { "type": "command", "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/session-register.sh" }
      ]
    }
  ]
}
